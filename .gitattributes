# WSL/Codex運用を前提に、既定はLFへ統一
* text=auto eol=lf

# Visual Studio / MSBuildファイルはCRLFを維持
*.sln               text eol=crlf
*.slnx              text eol=crlf
*.vcxproj           text eol=crlf
*.vcxproj.filters   text eol=crlf
*.props             text eol=crlf
*.targets           text eol=crlf

# Windowsスクリプト
*.bat               text eol=crlf
*.cmd               text eol=crlf
*.ps1               text eol=crlf

# Unix系スクリプトと設定ファイル
*.sh                text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
*.toml              text eol=lf
*.md                text eol=lf
*.txt               text eol=lf

# C/C++ ソースはWSL実行のためLFを既定化
*.c                 text eol=lf
*.cc                text eol=lf
*.cpp               text eol=lf
*.cxx               text eol=lf
*.h                 text eol=lf
*.hh                text eol=lf
*.hpp               text eol=lf
*.hxx               text eol=lf
*.inl               text eol=lf

# CMake
CMakeLists.txt      text eol=lf
*.cmake             text eol=lf

# バイナリアセット
*.png               binary
*.jpg               binary
*.jpeg              binary
*.gif               binary
*.bmp               binary
*.tga               binary
*.dds               binary
*.ico               binary
*.fbx               binary
*.obj               binary
*.wav               binary
*.mp3               binary
*.ogg               binary
*.ttf               binary
*.otf               binary
